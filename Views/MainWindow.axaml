<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PilotApp.ViewModels"
        xmlns:views="clr-namespace:PilotApp.Views"
        x:Class="PilotApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200" Height="720"
        MinWidth="900" MinHeight="560"
        Title="PilotApp — ИС управления проектами">

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="#2D2D2D" Padding="12,8">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Background="#4A90D9" CornerRadius="4" Padding="8,4">
            <TextBlock Text="PMO" Foreground="White" FontWeight="Bold" FontSize="13"/>
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="1">
            <TextBlock Text="PilotApp" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Информационная система управления проектами"
                       Foreground="#AAAAAA" FontSize="10"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Command="{Binding ToggleSearchCommand}"
                  Background="#444444" Foreground="White"
                  BorderBrush="#666666" BorderThickness="1"
                  Padding="12,6" Content="🔍  Поиск"/>

          <Button Command="{Binding ExportTasksCsvCommand}"
                  Background="#444444" Foreground="White"
                  BorderBrush="#666666" BorderThickness="1"
                  Padding="12,6" Content="↓ Задачи CSV"/>

          <Button Command="{Binding ExportTimeCsvCommand}"
                  Background="#444444" Foreground="White"
                  BorderBrush="#666666" BorderThickness="1"
                  Padding="12,6" Content="↓ Время CSV"/>

          <Button Command="{Binding ExportDocumentsCsvCommand}"
                  Background="#444444" Foreground="White"
                  BorderBrush="#666666" BorderThickness="1"
                  Padding="12,6" Content="↓ Документы CSV"/>

          <ToggleSwitch IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                        OffContent="Светлая" OnContent="Тёмная"
                        Foreground="White">
            <ToggleSwitch.Resources>
              <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="#888888"/>
              <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="White"/>
              <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="#AAAAAA"/>
              <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPointerOver" Color="White"/>
            </ToggleSwitch.Resources>
          </ToggleSwitch>

          <Button Command="{Binding LoadDataCommand}" IsEnabled="{Binding !IsBusy}"
                  Background="#444444" Foreground="White"
                  BorderBrush="#666666" BorderThickness="1"
                  Padding="12,6" Content="⬇  Загрузить"/>

          <Button Command="{Binding SaveDataCommand}" IsEnabled="{Binding !IsBusy}"
                  Background="#444444" Foreground="White"
                  BorderBrush="#666666" BorderThickness="1"
                  Padding="12,6" Content="⬆  Сохранить"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <TabControl Margin="8">
        <TabItem Header="{Binding TasksHeader}">
          <views:TasksView DataContext="{Binding Tasks}"/>
        </TabItem>
        <TabItem Header="{Binding DocumentsHeader}">
          <views:DocumentsView DataContext="{Binding Documents}"/>
        </TabItem>
        <TabItem Header="{Binding TimeHeader}">
          <views:TimeView DataContext="{Binding Time}"/>
        </TabItem>
        <TabItem Header="{Binding KanbanHeader}">
          <views:KanbanView DataContext="{Binding Kanban}"/>
        </TabItem>
        <TabItem Header="{Binding DashboardHeader}">
          <views:DashboardView DataContext="{Binding Dashboard}"/>
        </TabItem>
      </TabControl>
      
      <views:GlobalSearchView DataContext="{Binding GlobalSearch}"/>
    </Grid>

    <Border Grid.Row="2" Padding="12,6" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                   FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
        <ProgressBar Grid.Column="1" IsIndeterminate="True"
                     IsVisible="{Binding IsBusy}" Width="120" Height="4"/>
      </Grid>
    </Border>
  </Grid>
</Window>