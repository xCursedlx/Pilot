<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PilotApp.ViewModels"
        xmlns:views="clr-namespace:PilotApp.Views"
        x:Class="PilotApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200" Height="720"
        MinWidth="900" MinHeight="560"
        Title="PilotApp">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding ToggleSearchCommand}"/>
    <KeyBinding Gesture="Escape" Command="{Binding ToggleSearchCommand}"/>
  </Window.KeyBindings>

  <Grid>

    <Grid RowDefinitions="Auto,*,Auto">

      <Border Grid.Row="0"
              Padding="12,8"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="10"
                      VerticalAlignment="Center">
            <TextBlock Text="PilotApp"
                       FontSize="16"
                       FontWeight="Bold"/>
            <Border Background="#c0392b"
                    CornerRadius="10"
                    Padding="7,2"
                    IsVisible="{Binding HasOverdueTasks}"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding OverdueTasksCount, StringFormat='{}{0} просрочено'}"
                         Foreground="White"
                         FontSize="11"
                         FontWeight="SemiBold"/>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="6"
                      HorizontalAlignment="Center">
            <Button Content="Поиск  Ctrl+F"
                    Command="{Binding ToggleSearchCommand}"
                    FontSize="12"/>
            <Button Content="Задачи CSV"
                    Command="{Binding ExportTasksCsvCommand}"
                    FontSize="12"/>
            <Button Content="Время CSV"
                    Command="{Binding ExportTimeCsvCommand}"
                    FontSize="12"/>
            <Button Content="Документы CSV"
                    Command="{Binding ExportDocumentsCsvCommand}"
                    FontSize="12"/>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="8">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <TextBlock Text="Светлая"
                         FontSize="12"
                         VerticalAlignment="Center"
                         Opacity="0.7"/>
              <ToggleSwitch IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                            OnContent=""
                            OffContent=""
                            VerticalAlignment="Center"/>
              <TextBlock Text="Тёмная"
                         FontSize="12"
                         VerticalAlignment="Center"
                         Opacity="0.7"/>
            </StackPanel>
            <Button Content="Сохранить"
                    Command="{Binding SaveDataCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
            <Button Content="Загрузить"
                    Command="{Binding LoadDataCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>

        </Grid>
      </Border>

      <TabControl Grid.Row="1" Margin="8">
        <TabItem Header="{Binding TasksHeader}">
          <views:TasksView DataContext="{Binding Tasks}"/>
        </TabItem>
        <TabItem Header="{Binding DocumentsHeader}">
          <views:DocumentsView DataContext="{Binding Documents}"/>
        </TabItem>
        <TabItem Header="{Binding TimeHeader}">
          <views:TimeView DataContext="{Binding Time}"/>
        </TabItem>
        <TabItem Header="{Binding KanbanHeader}">
          <views:KanbanView DataContext="{Binding Kanban}"/>
        </TabItem>
      </TabControl>

      <Border Grid.Row="2"
              Padding="12,6"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding StatusMessage}"
                     FontSize="12"
                     Opacity="0.7"
                     VerticalAlignment="Center"/>
          <ProgressBar Grid.Column="1"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsBusy}"
                       Width="120"
                       Height="4"/>
        </Grid>
      </Border>

    </Grid>

    <views:GlobalSearchView DataContext="{Binding GlobalSearch}"/>

  </Grid>
</Window>