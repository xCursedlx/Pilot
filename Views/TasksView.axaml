<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             xmlns:models="clr-namespace:PilotApp.Models"
             x:DataType="vm:TasksViewModel"
             x:Class="PilotApp.Views.TasksView">

  <Grid RowDefinitions="Auto,*" Margin="12">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <Button Content="+ Добавить" Command="{Binding AddTaskCommand}"/>
      <Button Content="Удалить" Command="{Binding DeleteTaskCommand}"/>
      <TextBox Watermark="Поиск по названию / исполнителю"
               Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="240"/>
      <ComboBox ItemsSource="{Binding FilterStatuses}"
                SelectedItem="{Binding FilterStatus, Mode=TwoWay}" Width="150">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Converter={StaticResource TaskStatusConverter}}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBox Watermark="Фильтр по проекту"
               Text="{Binding FilterProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Width="160"/>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="2*,3*">
      <ListBox Grid.Column="0"
               Margin="0,0,10,0"
               ItemsSource="{Binding FilteredTasks}"
               SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto" Margin="4,3">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding Title}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Assignee}"
                           FontSize="11" Opacity="0.6"
                           IsVisible="{Binding Assignee,
                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding Project}"
                           FontSize="11" Opacity="0.5"
                           IsVisible="{Binding Project,
                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock FontSize="11"
                           Foreground="{Binding DueDate,
                             Converter={StaticResource DueDateColorConverter}}"
                           IsVisible="{Binding DueDate,
                             Converter={x:Static ObjectConverters.IsNotNull}}">
                  <TextBlock.Text>
                    <MultiBinding StringFormat=" {0:dd.MM.yyyy}">
                      <Binding Path="DueDate"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
                
                <TextBlock Text="{Binding Priority,
                             Converter={StaticResource TaskPriorityConverter}}"
                           FontSize="10"
                           Foreground="{Binding Priority,
                             Converter={StaticResource TaskPriorityConverter},
                             ConverterParameter=color}"
                           Opacity="0.85"/>
              </StackPanel>
              <Border Grid.Column="1"
                      Background="{Binding Status,
                        Converter={StaticResource TaskStatusColorConverter}}"
                      CornerRadius="4" Padding="6,2"
                      VerticalAlignment="Top" Margin="6,0,0,0">
                <TextBlock Text="{Binding Status,
                             Converter={StaticResource TaskStatusConverter}}"
                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
              </Border>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="8"
                    IsEnabled="{Binding SelectedTask,Converter={x:Static ObjectConverters.IsNotNull}}"
                    Margin="4,0,0,0">
          <TextBlock Text="Карточка задачи" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>

          <TextBlock Text="Название"/>
          <TextBox Text="{Binding SelectedTask.Title, Mode=TwoWay}"/>

          <TextBlock Text="Описание"/>
          <TextBox Text="{Binding SelectedTask.Description, Mode=TwoWay}"
                   AcceptsReturn="True" MinHeight="60"/>

          <TextBlock Text="Исполнитель"/>
          <TextBox Text="{Binding SelectedTask.Assignee, Mode=TwoWay}" Watermark="Имя сотрудника"/>

          <TextBlock Text="Проект"/>
          <TextBox Text="{Binding SelectedTask.Project, Mode=TwoWay}" Watermark="Название проекта"/>

          <TextBlock Text="Срок выполнения"/>
          <CalendarDatePicker SelectedDate="{Binding SelectedTask.DueDate, Mode=TwoWay}"/>

          <TextBlock Text="Статус"/>
          <ComboBox ItemsSource="{Binding Statuses}"
                    SelectedItem="{Binding SelectedTask.Status, Mode=TwoWay}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Width="10" Height="10" CornerRadius="5"
                          VerticalAlignment="Center"
                          Background="{Binding Converter={StaticResource TaskStatusColorConverter}}"/>
                  <TextBlock Text="{Binding Converter={StaticResource TaskStatusConverter}}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Text="Приоритет"/>
          <ComboBox ItemsSource="{Binding Priorities}"
                    SelectedItem="{Binding SelectedTask.Priority, Mode=TwoWay}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border Width="10" Height="10" CornerRadius="5"
                          VerticalAlignment="Center"
                          Background="{Binding Converter={StaticResource TaskPriorityConverter},
                            ConverterParameter=color}"/>
                  <TextBlock Text="{Binding Converter={StaticResource TaskPriorityConverter}}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Button Content="Применить изменения"
                  Command="{Binding SaveTaskCommand}"
                  HorizontalAlignment="Right" Margin="0,8,0,0"/>

          <Separator Margin="0,8,0,4"/>
          <TextBlock Text="Комментарии" FontSize="13" FontWeight="SemiBold"/>

          <ItemsControl ItemsSource="{Binding SelectedComments}" x:CompileBindings="False">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:TaskComment">
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,6">
                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Author}"
                                 FontWeight="SemiBold" FontSize="12"/>
                      <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                 FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="Автор"/>
          <TextBox Text="{Binding NewCommentAuthor, Mode=TwoWay}"
                   Watermark="Имя автора"/>
          <TextBlock Text="Комментарий"/>
          <TextBox Text="{Binding NewCommentText, Mode=TwoWay}"
                   Watermark="Текст комментария"
                   AcceptsReturn="True" MinHeight="60"/>
          <Button Content="Добавить комментарий"
                  Command="{Binding AddCommentCommand}"
                  HorizontalAlignment="Right"/>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>