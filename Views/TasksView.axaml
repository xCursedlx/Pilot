<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             x:DataType="vm:TasksViewModel"
             x:Class="PilotApp.Views.TasksView">

  <Grid RowDefinitions="Auto,*" Margin="12">
    <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,10">
      <Button Content="Добавить" Command="{Binding AddTaskCommand}"/>
      <Button Content="Удалить"  Command="{Binding DeleteTaskCommand}"/>
      <TextBox Watermark="Поиск по названию / исполнителю"
               Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Width="260"/>
      <ComboBox ItemsSource="{Binding FilterStatuses}"
                SelectedItem="{Binding FilterStatus, Mode=TwoWay}"
                Width="170">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Converter={StaticResource TaskStatusConverter}}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>
    
    <Grid Grid.Row="1" ColumnDefinitions="2*,3*">
      <ListBox Grid.Column="0"
               Margin="0,0,10,0"
               ItemsSource="{Binding FilteredTasks}"
               SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto" Margin="4,3">

              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding Title}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Assignee}"
                           FontSize="11"
                           Opacity="0.6"
                           IsVisible="{Binding Assignee,
                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock FontSize="11"
                           Foreground="{Binding DueDate,
                             Converter={StaticResource DueDateColorConverter}}"
                           IsVisible="{Binding DueDate,
                             Converter={x:Static ObjectConverters.IsNotNull}}">
                  <TextBlock.Text>
                    <MultiBinding StringFormat=" {0:dd.MM.yyyy}">
                      <Binding Path="DueDate"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>

              <Border Grid.Column="1"
                      Background="Gray"
                      CornerRadius="4"
                      Padding="6,2"
                      VerticalAlignment="Top"
                      Margin="6,0,0,0">
                <TextBlock Text="{Binding Status,
                             Converter={StaticResource TaskStatusConverter}}"
                           FontSize="11"/>
              </Border>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="8"
                    IsEnabled="{Binding SelectedTask,
                      Converter={x:Static ObjectConverters.IsNotNull}}"
                    Margin="4,0,0,0">

          <TextBlock Text="Карточка задачи"
                     FontSize="15"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>

          <TextBlock Text="Название"/>
          <TextBox Text="{Binding SelectedTask.Title, Mode=TwoWay}"/>

          <TextBlock Text="Описание"/>
          <TextBox Text="{Binding SelectedTask.Description, Mode=TwoWay}"
                   AcceptsReturn="True"
                   MinHeight="80"/>

          <TextBlock Text="Исполнитель"/>
          <TextBox Text="{Binding SelectedTask.Assignee, Mode=TwoWay}"
                   Watermark="Имя сотрудника"/>

          <TextBlock Text="Срок выполнения"/>
          <CalendarDatePicker SelectedDate="{Binding SelectedTask.DueDate, Mode=TwoWay}"/>

          <TextBlock Text="Статус"/>
          <ComboBox ItemsSource="{Binding Statuses}"
                    SelectedItem="{Binding SelectedTask.Status, Mode=TwoWay}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Converter={StaticResource TaskStatusConverter}}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Button Content="Применить изменения"
                  Command="{Binding SaveTaskCommand}"
                  HorizontalAlignment="Right"
                  Margin="0,8,0,0"/>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
