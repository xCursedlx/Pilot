<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             xmlns:models="clr-namespace:PilotApp.Models"
             x:DataType="vm:TasksViewModel"
             x:Class="PilotApp.Views.TasksView">

  <Grid RowDefinitions="Auto,*" Margin="12">

    <WrapPanel Grid.Row="0"
               Orientation="Horizontal"
               Margin="0,0,0,10">
      <Button Content="Добавить"
              Command="{Binding AddTaskCommand}"
              Margin="0,0,6,4"/>
      <Button Content="Удалить"
              Command="{Binding DeleteTaskCommand}"
              Margin="0,0,12,4"/>
      <TextBox Watermark="Поиск по названию / исполнителю"
               Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Width="220"
               Margin="0,0,6,4"/>
      <TextBox Watermark="Фильтр по проекту"
               Text="{Binding FilterProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Width="160"
               Margin="0,0,6,4"/>
      <ComboBox ItemsSource="{Binding FilterStatuses}"
                SelectedItem="{Binding FilterStatus, Mode=TwoWay}"
                Width="160"
                Margin="0,0,0,4">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Converter={StaticResource TaskStatusConverter}}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </WrapPanel>

    <Grid Grid.Row="1" ColumnDefinitions="2*,3*">

      <ListBox Grid.Column="0"
               Margin="0,0,10,0"
               ItemsSource="{Binding FilteredTasks}"
               SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="models:TaskItem">
            <Grid ColumnDefinitions="*,Auto" Margin="4,3">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding Title}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Assignee}"
                           FontSize="11"
                           Opacity="0.6"
                           IsVisible="{Binding Assignee,
                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding Project, StringFormat='/ {0}'}"
                           FontSize="11"
                           Opacity="0.55"
                           IsVisible="{Binding Project,
                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding DueDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                           FontSize="11"
                           Foreground="{Binding DueDate,
                             Converter={StaticResource DueDateColorConverter}}"
                           IsVisible="{Binding DueDate,
                             Converter={x:Static ObjectConverters.IsNotNull}}"/>
              </StackPanel>
              <Border Grid.Column="1"
                      Background="{Binding Priority,
                        Converter={StaticResource TaskPriorityConverter},
                        ConverterParameter=color}"
                      CornerRadius="4"
                      Padding="6,2"
                      VerticalAlignment="Top"
                      Margin="6,0,0,0">
                <TextBlock Text="{Binding Priority,
                             Converter={StaticResource TaskPriorityConverter}}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="White"/>
              </Border>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="10"
                    IsEnabled="{Binding SelectedTask,
                      Converter={x:Static ObjectConverters.IsNotNull}}">

          <TextBlock Text="Основное"
                     FontWeight="SemiBold"
                     FontSize="13"
                     Opacity="0.7"/>

          <StackPanel Spacing="4">
            <TextBlock Text="Название" FontSize="11" Opacity="0.6"/>
            <TextBox Text="{Binding SelectedTask.Title, Mode=TwoWay}"
                     Watermark="Название задачи"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Описание" FontSize="11" Opacity="0.6"/>
            <TextBox Text="{Binding SelectedTask.Description, Mode=TwoWay}"
                     Watermark="Описание"
                     AcceptsReturn="True"
                     Height="64"/>
          </StackPanel>

          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
              <TextBlock Text="Исполнитель" FontSize="11" Opacity="0.6"/>
              <TextBox Text="{Binding SelectedTask.Assignee, Mode=TwoWay}"
                       Watermark="Имя исполнителя"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="Проект" FontSize="11" Opacity="0.6"/>
              <TextBox Text="{Binding SelectedTask.Project, Mode=TwoWay}"
                       Watermark="Название проекта"/>
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
              <TextBlock Text="Срок" FontSize="11" Opacity="0.6"/>
              <CalendarDatePicker SelectedDate="{Binding SelectedTask.DueDate, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="Приоритет" FontSize="11" Opacity="0.6"/>
              <ComboBox ItemsSource="{Binding Priorities}"
                        SelectedItem="{Binding SelectedTask.Priority, Mode=TwoWay}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource TaskPriorityConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Grid>

          <StackPanel Spacing="4">
            <TextBlock Text="Статус" FontSize="11" Opacity="0.6"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ComboBox ItemsSource="{Binding Statuses}"
                        SelectedItem="{Binding SelectedTask.Status, Mode=TwoWay}"
                        Width="160">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource TaskStatusConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button Content="Сохранить"
                      Command="{Binding SaveTaskCommand}"/>
            </StackPanel>
          </StackPanel>

          <Expander Header="История статусов"
                    IsExpanded="False"
                    Margin="0,4,0,0">
            <ItemsControl ItemsSource="{Binding SelectedStatusHistory}"
                          Margin="0,6,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:StatusHistoryEntry">
                  <Border Padding="8,6"
                          Margin="0,0,0,4"
                          CornerRadius="4"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock FontSize="12">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}  -&gt;  {1}">
                              <Binding Path="OldStatus"
                                       Converter="{StaticResource TaskStatusConverter}"/>
                              <Binding Path="NewStatus"
                                       Converter="{StaticResource TaskStatusConverter}"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="{Binding ChangedBy, StringFormat='@ {0}'}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   IsVisible="{Binding ChangedBy,
                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      </StackPanel>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding ChangedAt, StringFormat='{}{0:dd.MM HH:mm}'}"
                                 FontSize="11"
                                 Opacity="0.5"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Expander>

          <Expander Header="Комментарии"
                    IsExpanded="True"
                    Margin="0,4,0,0">
            <StackPanel Spacing="8" Margin="0,6,0,0">

              <ItemsControl ItemsSource="{Binding SelectedComments}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="models:TaskComment">
                    <Border Padding="10,8"
                            Margin="0,0,0,6"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                      <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0"
                                     Text="{Binding Author}"
                                     FontWeight="SemiBold"
                                     FontSize="12"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM HH:mm}'}"
                                     FontSize="11"
                                     Opacity="0.5"/>
                        </Grid>
                        <TextBlock Text="{Binding Text}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Автор"
                           FontSize="11"
                           Opacity="0.6"
                           Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="Комментарий"
                           FontSize="11"
                           Opacity="0.6"/>
                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding NewCommentAuthor, Mode=TwoWay}"
                         Watermark="Ваше имя"
                         Width="120"
                         Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding NewCommentText, Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Текст комментария"/>
              </Grid>

              <Button Content="Добавить комментарий"
                      Command="{Binding AddCommentCommand}"
                      HorizontalAlignment="Left"/>
            </StackPanel>
          </Expander>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>
</UserControl>