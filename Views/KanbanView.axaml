<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             xmlns:models="clr-namespace:PilotApp.Models"
             x:DataType="vm:KanbanViewModel"
             x:Class="PilotApp.Views.KanbanView">

  <Grid RowDefinitions="Auto,*" Margin="12">

    <TextBlock Grid.Row="0"
               Text="Канбан-доска"
               FontSize="15"
               FontWeight="SemiBold"
               Margin="0,0,0,12"/>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,*,*"
          ColumnSpacing="10">

      <Border Grid.Column="0"
              CornerRadius="8"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top"
                  CornerRadius="8,8,0,0"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                  Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{Binding New.Title}"
                         FontWeight="SemiBold"
                         FontSize="13"/>
              <Border Grid.Column="1"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      CornerRadius="10"
                      Padding="8,2"
                      IsVisible="{Binding New.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding New.CountLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding New.Items}" Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:TaskItem">
                  <Border Margin="0,0,0,6"
                          Padding="10,8"
                          CornerRadius="6"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 FontSize="13"/>
                      <TextBlock Text="{Binding Assignee}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding Assignee,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <TextBlock Text="{Binding DueDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding DueDate,
                                   Converter={x:Static ObjectConverters.IsNotNull}}"/>
                      <TextBlock Text="{Binding Priority,
                                   Converter={StaticResource TaskPriorityConverter}}"
                                 FontSize="10"
                                 Opacity="0.7"/>
                      <Button Content="V работу"
                              FontSize="11"
                              HorizontalAlignment="Right"
                              Tag="InProgress"
                              Click="OnMoveButtonClicked"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="1"
              CornerRadius="8"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top"
                  CornerRadius="8,8,0,0"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                  Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{Binding InProgress.Title}"
                         FontWeight="SemiBold"
                         FontSize="13"/>
              <Border Grid.Column="1"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      CornerRadius="10"
                      Padding="8,2"
                      IsVisible="{Binding InProgress.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding InProgress.CountLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding InProgress.Items}" Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:TaskItem">
                  <Border Margin="0,0,0,6"
                          Padding="10,8"
                          CornerRadius="6"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 FontSize="13"/>
                      <TextBlock Text="{Binding Assignee}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding Assignee,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <TextBlock Text="{Binding DueDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding DueDate,
                                   Converter={x:Static ObjectConverters.IsNotNull}}"/>
                      <TextBlock Text="{Binding Priority,
                                   Converter={StaticResource TaskPriorityConverter}}"
                                 FontSize="10"
                                 Opacity="0.7"/>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="6"
                                  HorizontalAlignment="Right">
                        <Button Content="Назад"
                                FontSize="11"
                                Tag="New"
                                Click="OnMoveButtonClicked"/>
                        <Button Content="На проверку"
                                FontSize="11"
                                Tag="OnReview"
                                Click="OnMoveButtonClicked"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="2"
              CornerRadius="8"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top"
                  CornerRadius="8,8,0,0"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                  Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{Binding OnReview.Title}"
                         FontWeight="SemiBold"
                         FontSize="13"/>
              <Border Grid.Column="1"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      CornerRadius="10"
                      Padding="8,2"
                      IsVisible="{Binding OnReview.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding OnReview.CountLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding OnReview.Items}" Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:TaskItem">
                  <Border Margin="0,0,0,6"
                          Padding="10,8"
                          CornerRadius="6"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 FontSize="13"/>
                      <TextBlock Text="{Binding Assignee}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding Assignee,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <TextBlock Text="{Binding DueDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding DueDate,
                                   Converter={x:Static ObjectConverters.IsNotNull}}"/>
                      <TextBlock Text="{Binding Priority,
                                   Converter={StaticResource TaskPriorityConverter}}"
                                 FontSize="10"
                                 Opacity="0.7"/>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="6"
                                  HorizontalAlignment="Right">
                        <Button Content="В работу"
                                FontSize="11"
                                Tag="InProgress"
                                Click="OnMoveButtonClicked"/>
                        <Button Content="Готово"
                                FontSize="11"
                                Tag="Done"
                                Click="OnMoveButtonClicked"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="3"
              CornerRadius="8"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top"
                  CornerRadius="8,8,0,0"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                  Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{Binding Done.Title}"
                         FontWeight="SemiBold"
                         FontSize="13"/>
              <Border Grid.Column="1"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      CornerRadius="10"
                      Padding="8,2"
                      IsVisible="{Binding Done.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding Done.CountLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Done.Items}" Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:TaskItem">
                  <Border Margin="0,0,0,6"
                          Padding="10,8"
                          CornerRadius="6"
                          BorderThickness="1"
                          Opacity="0.65"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 FontSize="13"
                                 TextDecorations="Strikethrough"/>
                      <TextBlock Text="{Binding Assignee}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 IsVisible="{Binding Assignee,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                      <Button Content="На проверку"
                              FontSize="11"
                              HorizontalAlignment="Right"
                              Tag="OnReview"
                              Click="OnMoveButtonClicked"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </Grid>
</UserControl>