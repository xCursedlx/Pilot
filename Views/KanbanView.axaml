<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             xmlns:models="clr-namespace:PilotApp.Models"
             x:DataType="vm:KanbanViewModel"
             x:Class="PilotApp.Views.KanbanView">

  <UserControl.Resources>
    <DataTemplate x:Key="KanbanCardTemplate" DataType="models:TaskItem">
      <Border Margin="0,0,0,6"
              Padding="10,8"
              CornerRadius="6"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <StackPanel Spacing="5">
          <TextBlock Text="{Binding Title}"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     FontSize="13"/>

          <TextBlock Text="{Binding Assignee}"
                     FontSize="11" Opacity="0.6"
                     IsVisible="{Binding Assignee,
                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <TextBlock Text="{Binding Project}"
                     FontSize="11" Opacity="0.5"
                     IsVisible="{Binding Project,
                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <TextBlock FontSize="11"
                     Foreground="{Binding DueDate,
                       Converter={StaticResource DueDateColorConverter}}"
                     IsVisible="{Binding DueDate,
                       Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock.Text>
              <MultiBinding StringFormat=" {0:dd.MM.yyyy}">
                <Binding Path="DueDate"/>
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="4"
                    VerticalAlignment="Center"
                    Background="{Binding Priority,
                      Converter={StaticResource TaskPriorityConverter},
                      ConverterParameter=color}"/>
            <TextBlock Text="{Binding Priority,
                         Converter={StaticResource TaskPriorityConverter}}"
                       FontSize="11"
                       Foreground="{Binding Priority,
                         Converter={StaticResource TaskPriorityConverter},
                         ConverterParameter=color}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*" Margin="12">
    <TextBlock Grid.Row="0"
               Text="Канбан-доска"
               FontSize="15" FontWeight="SemiBold"
               Margin="0,0,0,12"/>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,*,*"
          ColumnSpacing="10">

      <Border Grid.Column="0" CornerRadius="8" BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0" Padding="12,10"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding New.Title}"
                         FontWeight="SemiBold" FontSize="13"/>
              <Border Grid.Column="1" CornerRadius="10" Padding="8,2"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      IsVisible="{Binding New.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding New.CountLabel}"
                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <StackPanel Margin="6">
              <ItemsControl ItemsSource="{Binding New.Items}"
                            ItemTemplate="{StaticResource KanbanCardTemplate}"/>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" CornerRadius="8" BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0" Padding="12,10"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding InProgress.Title}"
                         FontWeight="SemiBold" FontSize="13"/>
              <Border Grid.Column="1" CornerRadius="10" Padding="8,2"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      IsVisible="{Binding InProgress.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding InProgress.CountLabel}"
                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <StackPanel Margin="6">
              <ItemsControl ItemsSource="{Binding InProgress.Items}"
                            ItemTemplate="{StaticResource KanbanCardTemplate}"/>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" CornerRadius="8" BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0" Padding="12,10"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding OnReview.Title}"
                         FontWeight="SemiBold" FontSize="13"/>
              <Border Grid.Column="1" CornerRadius="10" Padding="8,2"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      IsVisible="{Binding OnReview.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding OnReview.CountLabel}"
                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <StackPanel Margin="6">
              <ItemsControl ItemsSource="{Binding OnReview.Items}"
                            ItemTemplate="{StaticResource KanbanCardTemplate}"/>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="3" CornerRadius="8" BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <DockPanel>
          <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0" Padding="12,10"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding Done.Title}"
                         FontWeight="SemiBold" FontSize="13"/>
              <Border Grid.Column="1" CornerRadius="10" Padding="8,2"
                      Background="{DynamicResource SystemControlHighlightAccentBrush}"
                      IsVisible="{Binding Done.CountLabel,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding Done.CountLabel}"
                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
              </Border>
            </Grid>
          </Border>
          <ScrollViewer>
            <StackPanel Margin="6">
              <ItemsControl ItemsSource="{Binding Done.Items}"
                            ItemTemplate="{StaticResource KanbanCardTemplate}"
                            Opacity="0.65"/>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>