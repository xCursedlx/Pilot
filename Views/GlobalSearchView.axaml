<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             x:DataType="vm:GlobalSearchViewModel"
             x:Class="PilotApp.Views.GlobalSearchView"
             IsVisible="{Binding IsVisible}">

  <Grid>
    <Border Background="#99000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

    <Border Width="640"
            MaxHeight="540"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Margin="0,60,0,0"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}">

      <Grid RowDefinitions="Auto,Auto,*">

        <Border Grid.Row="0"
                Padding="16,14"
                CornerRadius="12,12,0,0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0"
                       Text="[поиск]"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Opacity="0.6"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Query, Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged}"
                     Watermark="Поиск по задачам, документам, времени..."
                     BorderThickness="0"
                     Background="Transparent"
                     FontSize="15"/>
            <Button Grid.Column="2"
                    Content="X"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    Opacity="0.6"
                    Margin="8,0,0,0"
                    Click="OnCloseClicked"/>
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="16,6"
                BorderThickness="0,1,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                IsVisible="{Binding Query,
                  Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock FontSize="12"
                     Opacity="0.6"
                     Text="{Binding TotalCount, StringFormat='Найдено: {0}'}"/>
        </Border>

        <ScrollViewer Grid.Row="2"
                      MaxHeight="400"
                      Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
          <ItemsControl ItemsSource="{Binding Results}" Margin="8">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:SearchResult">
                <Border Padding="12,10"
                        Margin="0,0,0,4"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                  <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Background="{DynamicResource SystemControlHighlightAccentBrush}"
                            CornerRadius="6"
                            Padding="8,4"
                            Margin="0,0,12,0"
                            VerticalAlignment="Top">
                      <TextBlock Text="{Binding Category}"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="3">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 FontSize="13"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Subtitle}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>