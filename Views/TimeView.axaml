<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             xmlns:models="clr-namespace:PilotApp.Models"
             x:DataType="vm:TimeViewModel"
             x:CompileBindings="False"
             x:Class="PilotApp.Views.TimeView">

  <Grid RowDefinitions="Auto,*" Margin="12">

    <Border Grid.Row="0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="14"
            Margin="0,0,0,12"
            IsVisible="{Binding CanCreate}">
      <StackPanel Spacing="8">
        <TextBlock Text="Новая запись времени" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <Grid ColumnDefinitions="2*,2*,Auto,Auto">
          <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
            <TextBlock Text="Задача" FontSize="11" Opacity="0.7"/>
            <TextBox Text="{Binding NewTaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="Название задачи"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Margin="0,0,8,0" Spacing="4">
            <TextBlock Text="Исполнитель" FontSize="11" Opacity="0.7"/>
            <TextBox Text="{Binding NewUser, Mode=TwoWay}" Watermark="Имя сотрудника"/>
          </StackPanel>

          <StackPanel Grid.Column="2" Margin="0,0,8,0" Spacing="4">
            <TextBlock Text="Дата" FontSize="11" Opacity="0.7"/>
            <CalendarDatePicker SelectedDate="{Binding NewDate, Mode=TwoWay}"/>
          </StackPanel>

          <StackPanel Grid.Column="3" Spacing="4">
            <TextBlock Text="Часы" FontSize="11" Opacity="0.7"/>
            <NumericUpDown Value="{Binding NewHours, Mode=TwoWay}"
                           Minimum="0" Maximum="24" Increment="0.5"
                           FormatString="0.#" Width="110"/>
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
            <TextBlock Text="Комментарий" FontSize="11" Opacity="0.7"/>
            <TextBox Text="{Binding NewComment, Mode=TwoWay}" Watermark="Необязательно"/>
          </StackPanel>
          <Button Grid.Column="1"
                  Content="+ Добавить"
                  Command="{Binding AddEntryCommand}"
                  VerticalAlignment="Bottom"
                  FontWeight="SemiBold"/>
        </Grid>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="3*,2*">
      <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto" Margin="0,0,12,0">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
          <TextBox Grid.Column="0"
                   Watermark="Фильтр по исполнителю"
                   Text="{Binding FilterUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,8,0"/>
          <Button Grid.Column="1"
                  Content="Удалить выбранное"
                  Command="{Binding DeleteEntryCommand}"
                  IsVisible="{Binding CanDelete}"/>
        </Grid>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding FilteredEntries}"
                 SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:TimeEntry">
              <Grid ColumnDefinitions="*,Auto" Margin="4,3">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="{Binding TaskTitle}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock FontSize="11" Opacity="0.6">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0} · {1:dd.MM.yyyy}">
                        <Binding Path="User"/>
                        <Binding Path="Date"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                  <TextBlock Text="{Binding Comment}"
                             FontSize="11" Opacity="0.5"
                             IsVisible="{Binding Comment,
                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#1E88E5"
                        CornerRadius="4" Padding="8,2"
                        VerticalAlignment="Top" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Hours, StringFormat='{}{0:0.#} ч'}"
                             Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                </Border>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Padding="12,7" Margin="0,8,0,0" CornerRadius="4" Background="#2D2D2D">
          <TextBlock Foreground="White" FontWeight="SemiBold">
            <TextBlock.Text>
              <MultiBinding StringFormat="Итого (по фильтру): {0:0.#} ч">
                <Binding Path="TotalHours"/>
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </Border>
      </Grid>

      <Grid Grid.Column="1" RowDefinitions="*,Auto">
        <StackPanel Grid.Row="0" Spacing="6">
          <TextBlock Text="Часы по исполнителям" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ListBox ItemsSource="{Binding UserSummaries}" IsHitTestVisible="False" x:CompileBindings="False">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:UserSummary">
                <Grid ColumnDefinitions="*,Auto" Margin="4,2">
                  <TextBlock Grid.Column="0" Text="{Binding User}"
                             TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  <Border Grid.Column="1" Background="#43A047" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                    <TextBlock Text="{Binding Hours, StringFormat='{}{0:0.#} ч'}"
                               Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="6" Margin="0,16,0,0">
          <TextBlock Text="⚠ Записи прошлых дней"
                     FontSize="13" FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,4"/>
          <ListBox ItemsSource="{Binding OverdueEntries}"
                   IsHitTestVisible="False" MaxHeight="180" x:CompileBindings="False">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:TimeEntry">
                <StackPanel Spacing="2" Margin="4,2">
                  <TextBlock Text="{Binding TaskTitle}"
                             FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                  <TextBlock FontSize="11" Opacity="0.7">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0} · {1:dd.MM.yyyy} · {2:0.#} ч">
                        <Binding Path="User"/>
                        <Binding Path="Date"/>
                        <Binding Path="Hours"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</UserControl>