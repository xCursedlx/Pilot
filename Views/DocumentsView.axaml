<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PilotApp.ViewModels"
             x:DataType="vm:DocumentsViewModel"
             x:Class="PilotApp.Views.DocumentsView">

  <Grid RowDefinitions="Auto,*" Margin="12">
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <Button Content="Добавить" Command="{Binding AddDocumentCommand}"/>
      <Button Content="Удалить"  Command="{Binding DeleteDocumentCommand}"/>
      <TextBox Watermark="Поиск по названию / версии"
               Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Width="260"/>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="2*,3*">
      <ListBox Grid.Column="0"
               Margin="0,0,10,0"
               ItemsSource="{Binding FilteredDocuments}"
               SelectedItem="{Binding SelectedDocument, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,Auto" Margin="4,2">
              <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                           FontSize="11"
                           Opacity="0.6"/>
              </StackPanel>
              <Border Grid.Column="1"
                      Background="Gray"
                      CornerRadius="4"
                      Padding="6,2"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding Version}" FontSize="11"/>
              </Border>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="8"
                    IsEnabled="{Binding SelectedDocument, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Margin="4,0,0,0">

          <TextBlock Text="Карточка документа"
                     FontSize="15"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>

          <TextBlock Text="Название"/>
          <TextBox Text="{Binding SelectedDocument.Name, Mode=TwoWay}"/>

          <TextBlock Text="Описание"/>
          <TextBox Text="{Binding SelectedDocument.Description, Mode=TwoWay}"
                   AcceptsReturn="True"
                   MinHeight="80"/>

          <TextBlock Text="Версия"/>
          <ComboBox ItemsSource="{Binding Versions}"
                    SelectedItem="{Binding SelectedDocument.Version, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"/>

          <TextBlock Text="Связанная задача (ID или название)"/>
          <TextBox Text="{Binding SelectedDocument.LinkedTaskId, Mode=TwoWay}"/>

          <TextBlock Text="Путь к файлу"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding SelectedDocument.FilePath, Mode=TwoWay}"
                     IsReadOnly="True"
                     Watermark="Файл не выбран"/>
            <Button Grid.Column="1"
                    Content="Обзор…"
                    Command="{Binding PickFileCommand}"
                    Margin="6,0,0,0"/>
          </Grid>

          <TextBlock Text="{Binding SelectedDocument.CreatedAt, StringFormat='Создан: {0:dd.MM.yyyy HH:mm}'}"
                     Opacity="0.6"
                     FontSize="11"
                     Margin="0,4,0,0"/>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
