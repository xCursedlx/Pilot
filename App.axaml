<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PilotApp.Converters"
             x:Class="PilotApp.App">

    <Application.Resources>
        <conv:TaskStatusConverter x:Key="TaskStatusConverter"/>
        <conv:TaskStatusColorConverter x:Key="TaskStatusColorConverter"/>
        <conv:TaskPriorityConverter x:Key="TaskPriorityConverter"/>
        <conv:DueDateColorConverter x:Key="DueDateColorConverter"/>
        <conv:AuditSuccessColorConverter x:Key="AuditSuccessColorConverter"/>
        <conv:AuditEventTypeConverter x:Key="AuditEventTypeConverter"/>
        <conv:BoolToStringConverter x:Key="BoolToStringConverter"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
    </Application.Styles>

</Application>